preferredLabels = {\n?subject a veniss_ontology:Person.\n\n  ?subject crm:P1_is_identified_by ?given_name_node.\n  ?given_name_node crm:P2_has_type <https://veniss.net/resource/type/given_name>;\n                   rdfs:label ?given_name_label.\n  \n  OPTIONAL {\n    ?subject crm:P1_is_identified_by ?family_name_node.\n    ?family_name_node crm:P2_has_type <https://veniss.net/resource/type/family_name>;\n                      rdfs:label ?family_name_label.\n    BIND(CONCAT(?family_name_label\\, "\\, ") AS ?family_name)\n  }\n  BIND(COALESCE(?family_name\\, "") AS ?family_name_final)\n  BIND(CONCAT(?family_name_final\\, ?given_name_label) AS ?value)\n},{\n  ?subject a veniss_ontology:Group;\n      crm:P1_is_identified_by ?appellation.\n  ?appellation a crm:E41_Appellation;\n    crm:P2_has_type veniss_types:appellation;\n   \trdfs:label ?value\n},{\n?subject a veniss_ontology:Source_Primary; crm:P1_is_identified_by ?appellation.   ?appellation a crm:E41_Appellation;       crm:P2_has_type <https://veniss.net/resource/type/attributed_title>;       rdfs:label ?value\n},{\n  $subject a veniss_ontology:Source_Secondary;\ncrm:P1_is_identified_by ?bibitem_identifier.\n  ?bibitem_identifier a crm:E41_Appellation;\n    crm:P2_has_type <https://veniss.net/resource/type/title>;\n  \trdfs:label $value\n},{\n?subject a <http://www.cidoc-crm.org/cidoc-crm/E78_Collection> .\n\n  OPTIONAL { ?subject crm:P1_is_identified_by ?acr0 . ?acr0 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a0 . }\n  OPTIONAL { ?subject rdfs:label ?r0_it . FILTER(lang(?r0_it) = "it" || lang(?r0_it) = "") }\n  OPTIONAL { ?subject rdfs:label ?r0_en . FILTER(lang(?r0_en) = "en") }\n  BIND(COALESCE(STR(?a0)\\, STR(?r0_it)\\, STR(?r0_en)) AS ?n0)\n\n  OPTIONAL {\n    ?subject crm:P46i_forms_part_of ?p1 .\n    OPTIONAL { ?p1 crm:P1_is_identified_by ?acr1 . ?acr1 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a1 . }\n    OPTIONAL { ?p1 rdfs:label ?r1_it . FILTER(lang(?r1_it) = "it" || lang(?r1_it) = "") }\n    OPTIONAL { ?p1 rdfs:label ?r1_en . FILTER(lang(?r1_en) = "en") }\n    BIND(COALESCE(STR(?a1)\\, STR(?r1_it)\\, STR(?r1_en)) AS ?n1)\n\n    OPTIONAL {\n      ?p1 crm:P46i_forms_part_of ?p2 .\n      OPTIONAL { ?p2 crm:P1_is_identified_by ?acr2 . ?acr2 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a2 . }\n      OPTIONAL { ?p2 rdfs:label ?r2_it . FILTER(lang(?r2_it) = "it" || lang(?r2_it) = "") }\n      OPTIONAL { ?p2 rdfs:label ?r2_en . FILTER(lang(?r2_en) = "en") }\n      BIND(COALESCE(STR(?a2)\\, STR(?r2_it)\\, STR(?r2_en)) AS ?n2)\n\n      OPTIONAL {\n        ?p2 crm:P46i_forms_part_of ?p3 .\n        OPTIONAL { ?p3 crm:P1_is_identified_by ?acr3 . ?acr3 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a3 . }\n        OPTIONAL { ?p3 rdfs:label ?r3_it . FILTER(lang(?r3_it) = "it" || lang(?r3_it) = "") }\n        OPTIONAL { ?p3 rdfs:label ?r3_en . FILTER(lang(?r3_en) = "en") }\n        BIND(COALESCE(STR(?a3)\\, STR(?r3_it)\\, STR(?r3_en)) AS ?n3)\n\n        OPTIONAL {\n          ?p3 crm:P46i_forms_part_of ?p4 .\n          OPTIONAL { ?p4 crm:P1_is_identified_by ?acr4 . ?acr4 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a4 . }\n          OPTIONAL { ?p4 rdfs:label ?r4_it . FILTER(lang(?r4_it) = "it" || lang(?r4_it) = "") }\n          OPTIONAL { ?p4 rdfs:label ?r4_en . FILTER(lang(?r4_en) = "en") }\n          BIND(COALESCE(STR(?a4)\\, STR(?r4_it)\\, STR(?r4_en)) AS ?n4)\n\n          OPTIONAL {\n            ?p4 crm:P46i_forms_part_of ?p5 .\n            OPTIONAL { ?p5 crm:P1_is_identified_by ?acr5 . ?acr5 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a5 . }\n            OPTIONAL { ?p5 rdfs:label ?r5_it . FILTER(lang(?r5_it) = "it" || lang(?r5_it) = "") }\n            OPTIONAL { ?p5 rdfs:label ?r5_en . FILTER(lang(?r5_en) = "en") }\n            BIND(COALESCE(STR(?a5)\\, STR(?r5_it)\\, STR(?r5_en)) AS ?n5)\n\n            OPTIONAL {\n              ?p5 crm:P46i_forms_part_of ?p6 .\n              OPTIONAL { ?p6 crm:P1_is_identified_by ?acr6 . ?acr6 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a6 . }\n              OPTIONAL { ?p6 rdfs:label ?r6_it . FILTER(lang(?r6_it) = "it" || lang(?r6_it) = "") }\n              OPTIONAL { ?p6 rdfs:label ?r6_en . FILTER(lang(?r6_en) = "en") }\n              BIND(COALESCE(STR(?a6)\\, STR(?r6_it)\\, STR(?r6_en)) AS ?n6)\n\n              OPTIONAL {\n                ?p6 crm:P46i_forms_part_of ?p7 .\n                OPTIONAL { ?p7 crm:P1_is_identified_by ?acr7 . ?acr7 a crm:E41_Appellation ; crm:P2_has_type <https://veniss.net/resource/type/acronym> ; rdfs:label ?a7 . }\n                OPTIONAL { ?p7 rdfs:label ?r7_it . FILTER(lang(?r7_it) = "it" || lang(?r7_it) = "") }\n                OPTIONAL { ?p7 rdfs:label ?r7_en . FILTER(lang(?r7_en) = "en") }\n                BIND(COALESCE(STR(?a7)\\, STR(?r7_it)\\, STR(?r7_en)) AS ?n7)\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n\n  BIND(CONCAT(\n    IF(BOUND(?n7)\\, CONCAT(?n7\\, "\\, ")\\, "")\\,\n    IF(BOUND(?n6)\\, CONCAT(?n6\\, "\\, ")\\, "")\\,\n    IF(BOUND(?n5)\\, CONCAT(?n5\\, "\\, ")\\, "")\\,\n    IF(BOUND(?n4)\\, CONCAT(?n4\\, "\\, ")\\, "")\\,\n    IF(BOUND(?n3)\\, CONCAT(?n3\\, "\\, ")\\, "")\\,\n    IF(BOUND(?n2)\\, CONCAT(?n2\\, "\\, ")\\, "")\\,\n    IF(BOUND(?n1)\\, CONCAT(?n1\\, "\\, ")\\, "")\\,\n    COALESCE(?n0\\, "")\n  ) AS ?value)\n\n},{\n?subject a veniss_ontology:Island; \ncrm:P1_is_identified_by ?island_appellation.\n?island_appellation crm:P2_has_type <https://veniss.net/resource/type/appellation> ;\nrdfs:label ?value\n},<http://www.researchspace.org/ontology/displayLabel>,<http://www.w3.org/2000/01/rdf-schema#label>,<http://www.w3.org/2004/02/skos/core#prefLabel>
preferredThumbnails = { ?subject rso:PX_has_main_representation ?representation . ?representation a rso:EX_Digital_Image . ?representation crm:P1_is_identified_by/rso:PX_has_file_name ?fileName. BIND(CONCAT('/proxy/IIIF/'\\, ?fileName\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject rs:PX_has_main_representation ?representation . ?representation a rs:EX_Digital_Image . ?representation crmdig:L60i_is_documented_by/crmdig:L11_had_output/rs:PX_has_file_name ?fileName. BIND(CONCAT('/proxy/IIIF/'\\, ?fileName\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject rso:PX_has_main_representation ?representation . ?representation a rso:EX_Digital_Image . BIND(REPLACE(STR(?representation)\\, "^.*/(.*)$"\\, "$1") as ?imageID) . BIND(CONCAT('/proxy/IIIF/'\\, ?imageID\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject a rs:EX_Digital_Image . ?subject crmdig:L60i_is_documented_by/crmdig:L11_had_output/rs:PX_has_file_name ?fileName. BIND(CONCAT('/proxy/IIIF/'\\, ?fileName\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject a rso:EX_Digital_Image . ?subject crm:P1_is_identified_by/rso:PX_has_file_name ?fileName. BIND(CONCAT('/proxy/IIIF/'\\, ?fileName\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject a rso:EX_Digital_Image . BIND(REPLACE(STR(?subject)\\, "^.*/(.*)$"\\, "$1") as ?imageID) . BIND(CONCAT('/proxy/IIIF/'\\, ?imageID\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject crm:P138i_has_representation ?representation . ?representation a rso:EX_Digital_Image . ?representation crm:P1_is_identified_by/rso:PX_has_file_name ?fileName. BIND(CONCAT('/proxy/IIIF/'\\, ?fileName\\, '/full/!640\\,480/0/default.jpg') AS ?value) },{ ?subject crm:P138i_has_representation ?representation . ?representation a rso:EX_Digital_Image . BIND(REPLACE(STR(?representation)\\, "^.*/(.*)$"\\, "$1") as ?imageID) . BIND(CONCAT('/proxy/IIIF/'\\, ?imageID\\, '/full/!640\\,480/0/default.jpg') AS ?value) },<http://www.researchspace.org/ontology/PX_has_main_representation>,<http://www.cidoc-crm.org/cidoc-crm/P138i_has_representation>,{ ?object <http://www.researchspace.org/ontology/PX_has_main_representation> ?subject . BIND(?subject as ?value) }
templateIncludeQuery = PREFIX rso: <http://www.researchspace.org/ontology/> PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#> PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>  select ?type where { { FILTER(STRSTARTS(STR(??)\\, "http://www.researchspace.org/resource/user/")). BIND(rso:User as ?type). BIND(-1 as ?index) } UNION {?? <http://www.researchspace.org/ontology/PX_object_type>  ?type . BIND(0 AS ?index) } UNION {?? <http://www.cidoc-crm.org/cidoc-crm/P2_has_type>  ?type . BIND(1 AS ?index) } UNION { ?? a ?type . BIND(2 AS ?index) }  UNION { ?? a ?t .  ?t rdfs:subClassOf* ?type . FILTER (?type in (crm:E28_Conceptual_Object\\, crm:E24_Physical_Man-Made_Thing\\, crm:E39_Actor\\, crm:E53_Place\\, crm:E5_Event)). BIND(3 AS ?index) }  UNION { ?? a ?t . ?t rdfs:subClassOf+ ?type . BIND(4 AS ?index) } } ORDER BY ?index
deploymentTitle = VeNiss
